OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

CHROMA_PATH=data/vector_store/chroma
CHROMA_COLLECTION_NAME=research_paper_chunks_v1
VECTOR_DISTANCE_METRIC=cosine
VECTOR_UPSERT_BATCH_SIZE=64
RETRIEVAL_DEFAULT_TOP_K=5
RETRIEVAL_DEFAULT_CANDIDATE_K=20
RETRIEVAL_METADATA_WEIGHT=0.15
METADATA_SCHEMA_VERSION=1

# Optional: pin BGE to a local downloaded model for stable offline retrieval.
BGE_MODEL_PATH=data/models/bge-small-en-v1.5
BGE_OFFLINE=true

CONVERSATION_RECENT_MESSAGE_LIMIT=8
CONVERSATION_SUMMARY_TRIGGER_MESSAGES=12
CONVERSATION_SUMMARY_KEEP_RECENT=6
